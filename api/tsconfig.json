{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["./lib/*"],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "pages/api/health.openada.ts",
    "worker.ts",
    "pages/api/v1/**/*.openada.ts",
    "pages/api/v2/**/*.openada.ts",
    "lib/openada/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
