{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublishOpenADACftFiles",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::openada-us/cloudformation/*",
        "arn:aws:s3:::openada-us/widgets/*",
        "arn:aws:s3:::openada-us/ada.sh"
      ]
    },
    {
      "Sid": "ReadOpenADACftBucketLocation",
      "Effect": "Allow",
      "Action": "s3:GetBucketLocation",
      "Resource": "arn:aws:s3:::openada-us"
    }
  ]
}
