FROM node:24-bookworm-slim

LABEL org.opencontainers.image.title="OpenADA MCP AgentCore" \
      org.opencontainers.image.description="Stateless OpenADA MCP gateway for Amazon Bedrock AgentCore Runtime" \
      org.opencontainers.image.source="https://github.com/techcto/openada"

WORKDIR /app

COPY --chown=node:node agentcore/package.json ./package.json
COPY --chown=node:node agentcore/server.mjs ./server.mjs

ENV NODE_ENV=production
ENV PORT=8000

USER node
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://127.0.0.1:8000/ping', (res) => process.exit(res.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"

ENTRYPOINT ["node", "server.mjs"]
